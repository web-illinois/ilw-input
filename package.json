{
    "name": "@illinois-toolkit/ilw-input",
    "description": "Provides classes to style inputs and form elements.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/web-illinois/ilw-input.git"
    },
    "private": false,
    "license": "MIT",
    "version": "1.0.3-alpha",
    "type": "module",
    "files": [
        "src/**",
        "dist/**",
        "builder/**"
    ],
    "exports": {
        ".": {
            "import": "./dist/ilw-input.js",
            "require": "./dist/ilw-input.cjs",
            "default": "./dist/ilw-input.js"
        },
        "./ilw-input.css": {
            "import": "./dist/ilw-input.css"
        }
    },
    "main": "./dist/ilw-input.js",
    "module": "./dist/ilw-input.js",
    "publishConfig": {
        "access": "public",
        "tag": "alpha"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build --config vite.transpile.config.ts --emptyOutDir && vite build --config vite.build.config.ts --emptyOutDir",
        "preview": "vite preview",
        "prepack": "npm run build",
        "test:axe": "playwright test",
        "test:axe:github": "playwright test --config playwright.ci.config.ts",
        "test": "vitest run --browser.headless",
        "test:browser": "vitest watch --browser chromium"
    },
    "dependencies": {
        "lit": "3.1.3"
    },
    "devDependencies": {
        "@illinois-toolkit/ilw-core": "^1.0.2",
        "@playwright/test": "^1.54.1",
        "@vitest/browser": "^3.2.4",
        "vitest-browser-lit": "^0.1.0",
        "playwright": "^1.54.1",
        "typescript": "^5.9.2",
        "vite": "^7.1.3",
        "vite-plugin-dts": "^4.5.4"
    }
}
